{
  "name": "thirdparty-knowledge-base",
  "type": "thirdparty",
  "version": "2.0",
  "description": "第三方组件库知识库",
  "source": {
    "type": "link",
    "paths": [
      {
        "name": "madCollection",
        "path": "C:/Components/madCollection/Source"
      },
      {
        "name": "ICS",
        "path": "C:/Components/ICS/Source"
      }
    ],
    "extensions": [
      ".pas",
      ".dfm",
      ".inc"
    ],
    "encoding": "utf-8",
    "use_files_dir": false
  },
  "database": {
    "file": "knowledge_base.sqlite",
    "enable_vector_cache": true,
    "cache_size": 10000,
    "vector_build_mode": "ondemand"
  },
  "build": {
    "auto_rebuild": false,
    "incremental": true,
    "parallel_workers": 4,
    "batch_size": 1000
  }
}