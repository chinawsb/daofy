{
  "test_name": "新建客户-成功路径",
  "app_path": "C:/App/CustomerApp.exe",
  "target_form": "TNewCustomerForm",
  "version": 1,
  "created": "2026-06-18T15:00:00",
  "source_hash": "",
  "source_files": [
    "UnitCustomer.pas",
    "UnitCustomer.dfm"
  ],
  "run_count": 0,
  "steps": [
    {
      "phase": "perceive",
      "cmd": "formsum",
      "note": "获取当前窗体快照，确认初始状态"
    },
    {
      "phase": "perceive",
      "cmd": "rget",
      "target": "edtName.Text",
      "expected": "客户名称输入框初始为空",
      "assert_expr": "actual == ''"
    },
    {
      "phase": "perceive",
      "cmd": "capture",
      "capture": "before_input",
      "note": "留存操作前截图基线"
    },
    {
      "phase": "execute",
      "cmd": "type",
      "target": "edtName",
      "text": "张三"
    },
    {
      "phase": "verify",
      "cmd": "rget",
      "target": "edtName.Text",
      "expected": "客户名称已输入",
      "assert_expr": "actual == '张三'"
    },
    {
      "phase": "execute",
      "cmd": "type",
      "target": "edtAge",
      "text": "25"
    },
    {
      "phase": "verify",
      "cmd": "rget",
      "target": "edtAge.Text",
      "expected": "年龄已输入",
      "assert_expr": "actual == '25'"
    },
    {
      "phase": "verify",
      "cmd": "rget",
      "target": "btnSave.Enabled",
      "expected": "保存按钮在输入后可用",
      "assert_expr": "actual == 'True'"
    },
    {
      "phase": "execute",
      "cmd": "click",
      "target": "btnSave"
    },
    {
      "phase": "verify",
      "cmd": "msgscan",
      "expected": "无错误弹窗",
      "assert_expr": "actual == ''"
    },
    {
      "phase": "verify",
      "cmd": "waitfor",
      "target": "TMainForm",
      "timeout": 5000,
      "expected": "等待返回主窗口",
      "assert_expr": "actual == 'ok'"
    },
    {
      "phase": "verify",
      "cmd": "capture",
      "capture": "after_save",
      "note": "留存操作后截图"
    },
    {
      "phase": "verify",
      "cmd": "rget",
      "target": "lblStatus.Caption",
      "expected": "状态栏显示保存成功",
      "assert_expr": "actual == '保存成功'"
    }
  ]
}
